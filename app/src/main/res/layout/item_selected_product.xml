<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/edittext_border"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvSelectedName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/black"/>
        <TextView
            android:id="@+id/tvSelectedCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/tvOutOfStockLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HẾT HÀNG"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:background="#F44336"
            android:paddingHorizontal="6dp"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvSelectedPrice"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#E91E63"
        android:textStyle="bold"
        android:layout_marginEnd="10dp"/>

    <LinearLayout
        android:id="@+id/layoutQuantityControl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#F5F5F5">
        <ImageButton android:id="@+id/btnMinusQuantity" android:layout_width="32dp" android:layout_height="32dp" android:src="@drawable/ic_minus" app:tint="#F44336" android:background="?attr/selectableItemBackgroundBorderless"/>
        <TextView android:id="@+id/tvSelectedQuantity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="30dp" android:gravity="center" android:textStyle="bold"/>
        <ImageButton android:id="@+id/btnPlusQuantity" android:layout_width="32dp" android:layout_height="32dp" android:src="@android:drawable/ic_input_add" app:tint="#4CAF50" android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>
</LinearLayout>