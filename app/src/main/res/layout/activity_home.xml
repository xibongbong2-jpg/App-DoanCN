<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:titleTextColor="#FFFFFF" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F0F2F5"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THÔNG TIN NHÂN VIÊN"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#3F51B5"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="24dp"/>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="15dp"
                    app:cardElevation="8dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imgHomeAvatar"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            android:padding="2dp"
                            app:strokeColor="#3F51B5"
                            app:strokeWidth="2dp"
                            app:shapeAppearanceOverlay="@style/CircleImage"
                            android:src="@drawable/ic_add_pp"
                            android:layout_marginBottom="16dp"/>

                        <TextView
                            android:id="@+id/tvHomeFullName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tên Nhân Viên"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#222222"/>

                        <View
                            android:layout_width="100dp"
                            android:layout_height="2dp"
                            android:background="#3F51B5"
                            android:layout_marginVertical="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView android:id="@+id/tvHomeRole"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chức vụ: Admin"
                                android:textSize="16sp"
                                android:padding="8dp"/>

                            <TextView android:id="@+id/tvHomeDept"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Bộ phận: Quản lý"
                                android:textSize="16sp"
                                android:padding="8dp"/>

                            <TextView android:id="@+id/tvHomeDob"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Ngày sinh: 1990-01-01"
                                android:textSize="16sp"
                                android:padding="8dp"/>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/nav_header_home"
        app:menu="@menu/home_menu" />

</androidx.drawerlayout.widget.DrawerLayout>