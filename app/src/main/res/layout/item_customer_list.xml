<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCusName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tên khách hàng"
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvCusCredit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điểm: 100"
                    android:textColor="#FF9800"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvChiTiet"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:paddingTop="5dp"
                    android:paddingBottom="4dp"
                    android:text="Chi tiết >"
                    android:textColor="#2196F3"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tvCusId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mã KH: #05"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvCusPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="SĐT: 0123456789"
            android:textColor="#2196F3" />

        <TextView
            android:id="@+id/tvCusAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Địa chỉ: Hà Nội"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginLeft="24dp"
            android:gravity="end">

            <Button
                android:id="@+id/btnEditCustomer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sửa"
                android:textSize="12sp"
                android:backgroundTint="#4CAF50"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"/>

            <Button
                android:id="@+id/btnDeleteCustomer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xóa"
                android:textSize="12sp"
                android:backgroundTint="#F44336"
                android:textColor="@color/white"
                style="@style/Widget.MaterialComponents.Button.TextButton.Icon"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
