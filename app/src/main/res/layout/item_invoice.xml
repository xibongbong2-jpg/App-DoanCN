<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/layoutRight">

            <TextView
                android:id="@+id/tvInvoiceId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã HD: #25"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/black"/>

            <TextView
                android:id="@+id/tvInvoiceCustomer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID Khách hàng: 3"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvInvoiceEmployee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID Nhân viên: 1"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvInvoiceTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng: 107.485.000 VNĐ"
                android:textColor="#E91E63"
                android:textStyle="bold"
                android:textSize="15sp"
                android:layout_marginTop="5dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true">

            <View
                android:id="@+id/viewAlertDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginBottom="6dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/led_orange"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvInvoiceStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ xác nhận"
                android:textColor="#FF9800"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnViewDetail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chi tiết >"
                android:textColor="#3F51B5"
                android:textStyle="bold"
                android:paddingTop="12dp"
                android:textSize="14sp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>